.container {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 140rpx;
}

.header {
  margin-bottom: 32rpx;
}

.greeting {
  margin-bottom: 20rpx;
}

.greeting-text {
  font-size: 40rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #2C3E50 0%, #5D6D7E 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.checkin-status {
  display: inline-block;
}

.checkin-badge {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 107, 0.3);
}

.badge-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.badge-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.quick-actions {
  display: flex;
  gap: 24rpx;
  margin-bottom: 36rpx;
}

.action-btn {
  flex: 1;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 24rpx rgba(78, 205, 196, 0.15);
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 12rpx rgba(78, 205, 196, 0.1);
}

.action-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4ECDC4 0%, #3DBDB5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.4);
}

.action-icon-wrapper.checkin {
  background: linear-gradient(135deg, #FF6B6B 0%, #E55A5A 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.4);
}

.action-icon {
  font-size: 44rpx;
}

.action-text {
  font-size: 28rpx;
  color: #5D6D7E;
  font-weight: 600;
}

.section {
  margin-bottom: 36rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C3E50;
}

.section-more {
  font-size: 26rpx;
  color: #4ECDC4;
  font-weight: 500;
}

.empty-state {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(78, 205, 196, 0.1);
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #95A5A6;
}

.diary-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.diary-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(78, 205, 196, 0.12);
  transition: all 0.3s ease;
}

.diary-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(78, 205, 196, 0.08);
}

.card-content {
  margin-bottom: 20rpx;
}

.card-text {
  font-size: 30rpx;
  color: #2C3E50;
  line-height: 1.7;
}

.card-images {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.card-img {
  width: 192rpx;
  height: 192rpx;
  border-radius: 16rpx;
}

.more-images {
  width: 192rpx;
  height: 192rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #E8ECF0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.more-text {
  font-size: 30rpx;
  color: #95A5A6;
  font-weight: 600;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F4F8;
}

.card-time {
  font-size: 24rpx;
  color: #95A5A6;
}

.card-stats {
  display: flex;
  gap: 28rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #95A5A6;
}

.stat-item::before {
  margin-right: 8rpx;
}

.goal-scroll {
  white-space: nowrap;
}

.goal-list {
  display: inline-flex;
  gap: 24rpx;
}

.goal-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  width: 220rpx;
  box-shadow: 0 4rpx 20rpx rgba(78, 205, 196, 0.1);
}

.goal-progress-ring {
  position: relative;
  width: 136rpx;
  height: 136rpx;
  margin-bottom: 20rpx;
}

.ring-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 10rpx solid #F0F4F8;
}

.ring-progress {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 10rpx solid transparent;
  border-top-color: #4ECDC4;
  border-right-color: #4ECDC4;
  transform: rotate(calc(var(--progress) * 3.6deg - 90deg));
  transition: transform 0.6s ease;
}

.ring-inner {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  align-items: baseline;
}

.progress-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #4ECDC4;
}

.progress-total {
  font-size: 22rpx;
  color: #95A5A6;
}

.goal-title {
  font-size: 28rpx;
  color: #2C3E50;
  text-align: center;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.goal-status {
  background: linear-gradient(135deg, #E8F8F6 0%, #D4F1EE 100%);
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
}

.status-text {
  font-size: 22rpx;
  color: #4ECDC4;
  font-weight: 600;
}