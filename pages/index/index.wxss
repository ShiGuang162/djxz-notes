/* 全局容器 */
page {
  background: linear-gradient(180deg, #FFF9F5 0%, #FFF0E8 100%);
  min-height: 100vh;
}

.container {
  padding: 0;
  padding-bottom: 140rpx;
}

/* 顶部问候区 - 渐变背景 + 精致排版 */
.header {
  position: relative;
  padding: 48rpx 32rpx 40rpx;
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 182, 193, 0.15) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.header::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 223, 186, 0.2) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.greeting {
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.greeting-text {
  font-size: 44rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #FF8E8E 0%, #FFB6A8 50%, #FFD4A8 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(255, 142, 142, 0.2);
}

.checkin-status {
  position: relative;
  z-index: 1;
}

.checkin-badge {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  padding: 14rpx 28rpx;
  border-radius: 36rpx;
  box-shadow: 0 6rpx 24rpx rgba(255, 107, 107, 0.35);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 6rpx 24rpx rgba(255, 107, 107, 0.35);
  }
  50% {
    transform: scale(1.02);
    box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.45);
  }
}

.badge-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.15));
}

.badge-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

/* 快捷操作区 - 大卡片设计 */
.quick-actions {
  display: flex;
  gap: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  flex: 1;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 142, 142, 0.12);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.action-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #4ECDC4 0%, #3DBDB5 100%);
  border-radius: 28rpx 28rpx 0 0;
}

.action-btn.checkin::before {
  background: linear-gradient(90deg, #FF6B6B 0%, #E55A5A 100%);
}

.action-btn:active {
  transform: scale(0.96) translateY(4rpx);
  box-shadow: 0 4rpx 16rpx rgba(255, 142, 142, 0.08);
}

.action-icon-wrapper {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8F8F6 0%, #D4F1EE 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: inset 0 4rpx 12rpx rgba(78, 205, 196, 0.15);
  transition: all 0.3s ease;
}

.action-btn:active .action-icon-wrapper {
  transform: scale(0.9);
}

.action-icon-wrapper.checkin {
  background: linear-gradient(135deg, #FFE8E8 0%, #FFD4D4 100%);
  box-shadow: inset 0 4rpx 12rpx rgba(255, 107, 107, 0.15);
}

.action-icon {
  font-size: 48rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

.action-icon-img {
  width: 56rpx;
  height: 56rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

.action-text {
  font-size: 28rpx;
  color: #5D6D7E;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

/* 内容区块 - 精致卡片 */
.section {
  margin-bottom: 40rpx;
  padding: 0 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C3E50;
  letter-spacing: 1rpx;
  position: relative;
  padding-left: 24rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #FF8E8E 0%, #FFB6A8 100%);
  border-radius: 4rpx;
}

.section-more {
  font-size: 26rpx;
  color: #4ECDC4;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  transition: all 0.2s ease;
}

.section-more:active {
  color: #3DBDB5;
  transform: scale(0.95);
}

/* 空状态 */
.empty-state {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 80rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(255, 142, 142, 0.08);
  border: 2rpx dashed rgba(255, 142, 142, 0.2);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-icon-img {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.8;
}

.empty-text {
  font-size: 28rpx;
  color: #95A5A6;
  font-weight: 500;
}

/* 日记列表 - 精致卡片 */
.diary-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.diary-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(255, 142, 142, 0.1);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.diary-card:active {
  transform: scale(0.98) translateY(2rpx);
  box-shadow: 0 2rpx 12rpx rgba(255, 142, 142, 0.06);
}

.card-header {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 20rpx;
}

.card-time {
  font-size: 22rpx;
  color: #7F8C8D;
  background: linear-gradient(135deg, #FFF5F5 0%, #FFF0EB 100%);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
  border: 1rpx solid rgba(255, 182, 193, 0.2);
}

.card-content {
  margin-bottom: 24rpx;
}

.card-text {
  font-size: 30rpx;
  color: #2C3E50;
  line-height: 1.8;
  font-weight: 400;
}

.card-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.card-img-wrapper {
  width: calc((100% - 32rpx) / 3);
  aspect-ratio: 1;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.card-img {
  width: 100%;
  height: 100%;
  display: block;
  transition: all 0.3s ease;
}

.card-img-wrapper:active {
  transform: scale(0.95);
}

.more-images {
  width: calc((100% - 32rpx) / 3);
  aspect-ratio: 1;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #FFF5F5 0%, #FFF0EB 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed rgba(255, 182, 193, 0.3);
}

.more-text {
  font-size: 28rpx;
  color: #FF8E8E;
  font-weight: 600;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 182, 193, 0.15);
}

.card-stats {
  display: flex;
  gap: 32rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #95A5A6;
  font-weight: 500;
  transition: all 0.2s ease;
}

.stat-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 6rpx;
}

.stat-item:active {
  transform: scale(1.1);
}

/* 目标滚动区 */
.goal-scroll {
  white-space: nowrap;
}

.goal-list {
  display: inline-flex;
  gap: 20rpx;
}

.goal-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  width: 200rpx;
  box-shadow: 0 4rpx 20rpx rgba(78, 205, 196, 0.1);
  border: 1rpx solid rgba(78, 205, 196, 0.08);
}

.goal-progress-ring {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 16rpx;
}

.ring-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 10rpx solid #F0F4F8;
}

.ring-progress {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 10rpx solid transparent;
  border-top-color: #4ECDC4;
  border-right-color: #4ECDC4;
  transform: rotate(calc(var(--progress) * 3.6deg - 90deg));
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.ring-inner {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  align-items: baseline;
}

.progress-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #4ECDC4;
}

.progress-total {
  font-size: 20rpx;
  color: #95A5A6;
  margin-left: 4rpx;
}

.goal-title {
  font-size: 26rpx;
  color: #2C3E50;
  text-align: center;
  margin-bottom: 12rpx;
  font-weight: 600;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goal-status {
  background: linear-gradient(135deg, #E8F8F6 0%, #D4F1EE 100%);
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
}

.status-text {
  font-size: 22rpx;
  color: #4ECDC4;
  font-weight: 600;
}

/* 骨架屏样式 */
.skeleton {
  padding: 48rpx 32rpx;
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.skeleton-header {
  margin-bottom: 40rpx;
}

.skeleton-line {
  height: 44rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 8rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-actions {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.skeleton-action {
  flex: 1;
  height: 200rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 28rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-section {
  margin-bottom: 40rpx;
}

.skeleton-card {
  height: 160rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 入场动画 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.header {
  animation: fadeInUp 0.6s ease-out;
}

.quick-actions {
  animation: fadeInUp 0.6s ease-out 0.1s backwards;
}

.section {
  animation: fadeInUp 0.6s ease-out 0.2s backwards;
}
