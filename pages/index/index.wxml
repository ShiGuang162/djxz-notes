<view class="container">
  <view class="header">
    <view class="greeting">
      <text class="greeting-text">{{greeting}}，{{userInfo.nickName}}</text>
    </view>
    <view class="checkin-status" wx:if="{{continuousDays > 0}}">
      <view class="checkin-badge">
        <text class="badge-icon">🔥</text>
        <text class="badge-text">{{continuousDays}}天连续打卡</text>
      </view>
    </view>
  </view>

  <view class="quick-actions">
    <view class="action-btn" bindtap="goToWrite">
      <view class="action-icon-wrapper">
        <text class="action-icon">✏️</text>
      </view>
      <text class="action-text">写日记</text>
    </view>
    <view class="action-btn" bindtap="goToCheckin">
      <view class="action-icon-wrapper checkin">
        <text class="action-icon">✅</text>
      </view>
      <text class="action-text">今日打卡</text>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">我的日记</text>
      <text class="section-more" bindtap="viewAllDiaries">查看全部</text>
    </view>
    
    <view wx:if="{{diaryList.length === 0}}" class="empty-state">
      <text class="empty-icon">📝</text>
      <text class="empty-text">还没有日记，写一篇吧</text>
    </view>
    
    <view wx:else class="diary-list">
      <view 
        wx:for="{{diaryList}}" 
        wx:key="_id" 
        class="diary-card" 
        bindtap="goToDetail"
        data-id="{{item._id}}"
      >
        <view class="card-header">
          <text class="card-time">{{item.formattedTime}}</text>
        </view>
        <view class="card-content">
          <text class="card-text multiline">{{item.content}}</text>
        </view>
        <view class="card-images" wx:if="{{item.images && item.images.length > 0}}">
          <block wx:for="{{item.images}}" wx:key="index" wx:for-item="img">
            <view wx:if="{{index < 3}}" class="card-img-wrapper">
              <image class="card-img" src="{{img}}" mode="aspectFill" />
            </view>
          </block>
          <view wx:if="{{item.images.length > 3}}" class="more-images">
            <text class="more-text">+{{item.images.length - 3}}</text>
          </view>
        </view>
        <view class="card-footer">
          <view class="card-stats">
            <text class="stat-item">❤️ {{item.likes}}</text>
            <text class="stat-item">💬 {{item.commentCount || 0}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">我的目标</text>
      <text class="section-more" bindtap="goToGoals">管理目标</text>
    </view>
    
    <view wx:if="{{goalList.length === 0}}" class="empty-state">
      <image class="empty-icon-img" src="/images/target.png" mode="aspectFit"/>
      <text class="empty-text">还没有目标，设定一个吧</text>
    </view>
    
    <scroll-view wx:else class="goal-scroll" scroll-x>
      <view class="goal-list">
        <view 
          wx:for="{{goalList}}" 
          wx:key="_id" 
          class="goal-card"
          bindtap="goToGoalDetail"
          data-id="{{item._id}}"
        >
          <view class="goal-progress-ring">
            <view class="ring-bg"></view>
            <view class="ring-progress" style="--progress: {{(item.completedDays / item.targetDays) * 100}}%"></view>
            <view class="ring-inner">
              <text class="progress-num">{{item.completedDays}}</text>
              <text class="progress-total">/{{item.targetDays}}</text>
            </view>
          </view>
          <text class="goal-title">{{item.title}}</text>
          <view class="goal-status" wx:if="{{item.status === 'completed'}}">
            <text class="status-text">已完成</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>