<view class="container" wx:if="{{isLoaded}}">
  <view wx:if="{{diary}}" class="diary-detail">
    <view class="diary-content">
      <text class="content-text">{{diary.content}}</text>
    </view>

    <view class="diary-images" wx:if="{{diary.images && diary.images.length > 0}}">
      <image
        wx:for="{{diary.images}}"
        wx:key="index"
        class="detail-img"
        src="{{item}}"
        mode="widthFix"
        bindtap="previewImage"
        data-index="{{index}}"
      />
    </view>

    <view class="diary-meta">
      <text class="meta-time">{{diaryTime}}</text>
    </view>
  </view>

  <view class="divider"></view>

  <view class="comment-section">
    <view class="section-header">
      <text class="section-title">评论 ({{formattedComments.length}})</text>
    </view>

    <view wx:if="{{formattedComments.length === 0}}" class="empty-state">
      <text class="empty-text">还没有评论，来说两句吧</text>
    </view>

    <view wx:else class="comment-list">
      <view wx:for="{{formattedComments}}" wx:key="_id" class="comment-item">
        <view class="comment-avatar">
          <text class="avatar-icon">👤</text>
        </view>
        <view class="comment-content">
          <view class="comment-header">
            <text class="comment-user">匿名用户</text>
            <text class="comment-time">{{item.formattedTime}}</text>
          </view>
          <text class="comment-text">{{item.content}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="action-bar">
    <view class="action-item" bindtap="handleLike">
      <text class="action-icon {{liked ? 'liked' : ''}}">❤️</text>
      <text class="action-text">{{diary.likes || 0}}</text>
    </view>
    <view class="action-item" bindtap="focusComment">
      <text class="action-icon">💬</text>
      <text class="action-text">{{formattedComments.length}}</text>
    </view>
    <view class="action-item" bindtap="handleShare">
      <text class="action-icon">🔗</text>
      <text class="action-text">分享</text>
    </view>
  </view>

  <view class="input-area">
    <input
      class="comment-input"
      placeholder="写下你的评论..."
      value="{{commentText}}"
      bindinput="onCommentInput"
      bindconfirm="submitComment"
    />
    <button class="send-btn" bindtap="submitComment" disabled="{{!commentText.trim()}}">
      <text class="send-text">发送</text>
    </button>
  </view>
</view>

<view wx:else class="loading-state">
  <text>加载中...</text>
</view>
