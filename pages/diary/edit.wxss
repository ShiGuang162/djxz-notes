.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  padding-bottom: 140rpx;
}

.editor-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C3E50;
}

.save-btn {
  background: linear-gradient(135deg, #4ECDC4 0%, #3DBDB5 100%);
  padding: 16rpx 36rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.35);
}

.save-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.editor-body {
  padding: 24rpx 32rpx;
}

.content-input {
  width: 100%;
  min-height: 400rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  font-size: 32rpx;
  line-height: 1.8;
  color: #2C3E50;
  box-shadow: 0 4rpx 20rpx rgba(78, 205, 196, 0.1);
}

.content-input:focus {
  outline: none;
  box-shadow: 0 4rpx 20rpx rgba(78, 205, 196, 0.2);
}

.image-section {
  margin-top: 28rpx;
}

.section-title {
  font-size: 30rpx;
  color: #5D6D7E;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: calc((100% - 40rpx) / 3);
  aspect-ratio: 1;
  border-radius: 16rpx;
  overflow: hidden;
}

.image-item.add {
  background: linear-gradient(135deg, #FFFFFF 0%, #F8FAFC 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.1);
}

.add-icon {
  font-size: 56rpx;
  color: #4ECDC4;
}

.image-item.preview {
  position: relative;
}

.preview-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 28rpx;
  color: #FFFFFF;
}

.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 24rpx rgba(78, 205, 196, 0.1);
}

.action-row {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.98);
}

.action-btn.primary {
  background: linear-gradient(135deg, #4ECDC4 0%, #3DBDB5 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 20rpx rgba(78, 205, 196, 0.4);
}

.action-btn.secondary {
  background: linear-gradient(135deg, #FF6B6B 0%, #E55A5A 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 107, 0.4);
}