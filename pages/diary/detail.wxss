.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  padding-bottom: 140rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #F8FAFC 0%, #F0F4F8 100%);
  border-radius: 50%;
}

.back-icon {
  font-size: 44rpx;
  color: #5D6D7E;
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C3E50;
}

.detail-body {
  padding: 32rpx;
}

.diary-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 24rpx rgba(78, 205, 196, 0.12);
  margin-bottom: 32rpx;
}

.card-content {
  margin-bottom: 28rpx;
}

.content-text {
  font-size: 32rpx;
  color: #2C3E50;
  line-height: 1.9;
}

.card-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.card-img {
  width: calc((100% - 32rpx) / 3);
  aspect-ratio: 1;
  border-radius: 16rpx;
  object-fit: cover;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid #F0F4F8;
}

.card-time {
  font-size: 26rpx;
  color: #95A5A6;
}

.card-actions {
  display: flex;
  gap: 40rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.action-icon {
  font-size: 36rpx;
  transition: all 0.3s ease;
}

.action-icon.liked {
  animation: bounce 0.4s ease;
  color: #FF6B6B;
}

.action-text {
  font-size: 28rpx;
  color: #5D6D7E;
}

.comments-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(78, 205, 196, 0.12);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C3E50;
}

.section-count {
  font-size: 26rpx;
  color: #95A5A6;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #95A5A6;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.comment-item {
  display: flex;
  gap: 20rpx;
  padding-bottom: 28rpx;
  border-bottom: 1rpx solid #F0F4F8;
}

.comment-item:last-child {
  border-bottom: none;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4ECDC4 0%, #3DBDB5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.comment-content {
  flex: 1;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.comment-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
}

.comment-time {
  font-size: 24rpx;
  color: #95A5A6;
}

.comment-text {
  font-size: 30rpx;
  color: #5D6D7E;
  line-height: 1.7;
}

.input-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 24rpx rgba(78, 205, 196, 0.1);
}

.input-row {
  display: flex;
  gap: 20rpx;
}

.comment-input {
  flex: 1;
  height: 80rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F0F4F8 100%);
  border-radius: 40rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
}

.send-btn {
  width: 100rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #4ECDC4 0%, #3DBDB5 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.35);
}

.send-icon {
  font-size: 36rpx;
  color: #FFFFFF;
}

@keyframes bounce {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.3);
  }
}