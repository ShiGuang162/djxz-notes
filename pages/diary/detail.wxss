.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  padding-bottom: 140rpx;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  font-size: 32rpx;
  color: #95A5A6;
}

.diary-detail {
  background: #FFFFFF;
  border-radius: 28rpx;
  margin: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 24rpx rgba(78, 205, 196, 0.12);
}

.diary-content {
  margin-bottom: 28rpx;
}

.content-text {
  font-size: 32rpx;
  color: #2C3E50;
  line-height: 1.9;
}

.diary-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.detail-img {
  width: calc((100% - 32rpx) / 3);
  aspect-ratio: 1;
  border-radius: 16rpx;
  object-fit: cover;
}

.diary-meta {
  display: flex;
  justify-content: flex-end;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F4F8;
}

.meta-time {
  font-size: 24rpx;
  color: #95A5A6;
  background: linear-gradient(135deg, #F8FAFC 0%, #F0F4F8 100%);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.divider {
  height: 1rpx;
  background: #F0F4F8;
  margin: 0 24rpx;
}

.comment-section {
  background: #FFFFFF;
  margin: 24rpx;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(78, 205, 196, 0.12);
}

.section-header {
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C3E50;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #95A5A6;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.comment-item {
  display: flex;
  gap: 20rpx;
  padding-bottom: 28rpx;
  border-bottom: 1rpx solid #F0F4F8;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4ECDC4 0%, #3DBDB5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-icon {
  font-size: 36rpx;
}

.comment-content {
  flex: 1;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.comment-user {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
}

.comment-time {
  font-size: 24rpx;
  color: #95A5A6;
}

.comment-text {
  font-size: 30rpx;
  color: #5D6D7E;
  line-height: 1.7;
}

.action-bar {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
  margin: 0 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.08);
}

.action-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 32rpx;
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.action-item:active {
  background: #F8FAFC;
}

.action-icon {
  font-size: 40rpx;
  transition: all 0.3s ease;
}

.action-icon.liked {
  animation: bounce 0.4s ease;
}

.action-text {
  font-size: 28rpx;
  color: #5D6D7E;
  font-weight: 500;
}

.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 24rpx rgba(78, 205, 196, 0.1);
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.comment-input {
  flex: 1;
  height: 80rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F0F4F8 100%);
  border-radius: 40rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
}

.send-btn {
  width: 120rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #4ECDC4 0%, #3DBDB5 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.35);
  border: none;
  padding: 0;
}

.send-btn[disabled] {
  background: #E8ECF0;
  box-shadow: none;
}

.send-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
}

@keyframes bounce {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.3);
  }
}
