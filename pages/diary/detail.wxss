.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 200rpx;
}

.diary-detail {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.diary-content {
  margin-bottom: 24rpx;
}

.content-text {
  font-size: 32rpx;
  line-height: 1.8;
  color: #333;
}

.diary-images {
  margin-bottom: 24rpx;
}

.detail-img {
  width: 100%;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
}

.diary-meta {
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.meta-time {
  font-size: 26rpx;
  color: #999;
}

.divider {
  height: 20rpx;
  background: #f5f5f5;
}

.comment-section {
  background: #fff;
  margin: 0 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.empty-state {
  text-align: center;
  padding: 40rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.comment-item {
  display: flex;
  gap: 16rpx;
}

.comment-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-icon {
  font-size: 32rpx;
}

.comment-content {
  flex: 1;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.comment-user {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.comment-time {
  font-size: 24rpx;
  color: #999;
}

.comment-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.action-bar {
  position: fixed;
  bottom: 120rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 80rpx;
  background: #fff;
  padding: 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  font-size: 40rpx;
}

.action-icon.liked {
  animation: bounce 0.5s ease;
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.comment-input {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
}

.send-btn {
  background: linear-gradient(135deg, #52c41a 0%, #3db916 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

.send-btn[disabled] {
  background: #ccc;
}

.send-text {
  font-size: 28rpx;
}

@keyframes bounce {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.3);
  }
}