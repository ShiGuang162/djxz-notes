<view class="container">
  <view class="editor-header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <text class="header-title">写日记</text>
    <view class="save-btn" bindtap="submitDiary">
      <text class="save-text">保存</text>
    </view>
  </view>

  <view class="editor-body">
    <view class="input-section">
      <textarea 
        class="content-input" 
        placeholder="写下今天的心情和故事..." 
        value="{{content}}"
        bindinput="onContentInput"
        maxlength="2000"
        auto-height
      ></textarea>
      <view class="word-count">
        <text class="count-text">{{content.length}}/2000</text>
      </view>
    </view>

    <view class="image-section">
      <view class="section-title">
        <text class="title-text">添加图片</text>
        <text class="title-hint">最多添加9张</text>
      </view>
      <view class="image-list">
        <view 
          wx:for="{{images}}" 
          wx:key="index" 
          class="image-item preview"
        >
          <image class="preview-img" src="{{item}}" mode="aspectFill" />
          <view class="delete-btn" catchtap="deleteImage" data-index="{{index}}">
            <text class="delete-icon">×</text>
          </view>
        </view>
        <view 
          wx:if="{{images.length < 9}}" 
          class="image-item add"
          bindtap="chooseImage"
        >
          <text class="add-icon">+</text>
        </view>
      </view>
    </view>
  </view>

  <view class="footer-actions">
    <view class="action-row">
      <button class="action-btn primary" bindtap="submitDiary" disabled="{{!content.trim()}}">
        <text class="btn-text">保存日记</text>
      </button>
    </view>
  </view>
</view>
