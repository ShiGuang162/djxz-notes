.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  padding-bottom: 140rpx;
}

.checkin-header {
  position: relative;
  padding: 48rpx 32rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 440rpx;
  background: linear-gradient(135deg, #4ECDC4 0%, #3DBDB5 50%, #2DB5AD 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.header-content {
  position: relative;
  z-index: 1;
}

.checkin-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 36rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.stat-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 12rpx;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
}

.checkin-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border-radius: 48rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(78, 205, 196, 0.35);
  transition: all 0.3s ease;
}

.checkin-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.25);
}

.checkin-icon {
  font-size: 40rpx;
  color: #4ECDC4;
  margin-right: 16rpx;
}

.checkin-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #4ECDC4;
}

.checked-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
  border-radius: 48rpx;
  padding: 32rpx;
}

.badge-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.badge-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.calendar-section {
  background: #FFFFFF;
  margin: 24rpx;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(78, 205, 196, 0.12);
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.month-nav {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #F8FAFC 0%, #E8ECF0 100%);
  border-radius: 50%;
  transition: all 0.2s ease;
}

.month-nav:active {
  background: #4ECDC4;
}

.month-nav:active .nav-icon {
  color: #FFFFFF;
}

.nav-icon {
  font-size: 44rpx;
  color: #5D6D7E;
  font-weight: 300;
}

.month-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C3E50;
}

.weekdays {
  display: flex;
  margin-bottom: 20rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #95A5A6;
  font-weight: 600;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
}

.day-cell {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.2s ease;
}

.day-cell:active {
  background: rgba(78, 205, 196, 0.1);
  border-radius: 50%;
}

.day-num {
  font-size: 28rpx;
  color: #2C3E50;
}

.day-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4ECDC4 0%, #3DBDB5 100%);
  margin-top: 8rpx;
  box-shadow: 0 0 8rpx rgba(78, 205, 196, 0.4);
}

.day-today {
  position: absolute;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 4rpx solid #4ECDC4;
}

.goals-section {
  background: #FFFFFF;
  margin: 24rpx;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(78, 205, 196, 0.12);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C3E50;
}

.add-goal-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.add-icon {
  font-size: 36rpx;
  color: #4ECDC4;
}

.add-text {
  font-size: 28rpx;
  color: #4ECDC4;
  font-weight: 600;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #95A5A6;
}

.goal-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.goal-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F0F4F8 100%);
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.goal-card:active {
  transform: scale(0.98);
}

.goal-info {
  flex: 1;
  margin-right: 24rpx;
}

.goal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C3E50;
  display: block;
  margin-bottom: 8rpx;
}

.goal-desc {
  font-size: 24rpx;
  color: #95A5A6;
  display: block;
  margin-bottom: 16rpx;
}

.goal-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 14rpx;
  background: #E8ECF0;
  border-radius: 7rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4ECDC4 0%, #3DBDB5 100%);
  border-radius: 7rpx;
  transition: width 0.5s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #5D6D7E;
  font-weight: 600;
  white-space: nowrap;
}

.goal-action {
  flex-shrink: 0;
}

.action-btn {
  background: linear-gradient(135deg, #4ECDC4 0%, #3DBDB5 100%);
  padding: 16rpx 36rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.35);
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.95);
}

.btn-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.completed-badge {
  background: linear-gradient(135deg, #E8F8F6 0%, #D4F1EE 100%);
  padding: 16rpx 36rpx;
  border-radius: 24rpx;
}

.completed-badge .badge-text {
  font-size: 26rpx;
  color: #4ECDC4;
  font-weight: 600;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.2s ease;
}

.modal-content {
  width: 85%;
  background: #FFFFFF;
  border-radius: 32rpx;
  overflow: hidden;
  animation: scaleIn 0.3s ease;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F4F8;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C3E50;
}

.close-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border-radius: 50%;
}

.close-btn:active {
  background: rgba(0, 0, 0, 0.05);
}

.close-icon {
  font-size: 48rpx;
  color: #95A5A6;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 28rpx;
  color: #5D6D7E;
  display: block;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F0F4F8 100%);
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.form-input:focus {
  border-color: #4ECDC4;
  background: #FFFFFF;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #F0F4F8;
}

.modal-btn {
  flex: 1;
  padding: 32rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.modal-btn.cancel {
  color: #95A5A6;
  background: #F8FAFC;
}

.modal-btn.confirm {
  color: #FFFFFF;
  background: linear-gradient(135deg, #4ECDC4 0%, #3DBDB5 100%);
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes scaleIn {
  from { 
    opacity: 0; 
    transform: scale(0.9); 
  }
  to { 
    opacity: 1; 
    transform: scale(1); 
  }
}