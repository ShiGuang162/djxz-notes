.container {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 60rpx;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  font-size: 32rpx;
  color: #999;
}

.goal-header {
  position: relative;
  padding-bottom: 60rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 480rpx;
  background: linear-gradient(135deg, #FFE4E1 0%, #FFF0F5 30%, #FFE4EC 60%, #FFB6C1 100%);
  border-bottom-left-radius: 48rpx;
  border-bottom-right-radius: 48rpx;
}

.header-content {
  position: relative;
  padding: 40rpx 32rpx 20rpx;
}

.goal-top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.back-btn {
  width: 68rpx;
  height: 68rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.back-icon {
  font-size: 36rpx;
  color: #FF6B9D;
  font-weight: bold;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.action-icon-btn {
  width: 68rpx;
  height: 68rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  font-size: 32rpx;
}

.action-icon-btn.delete {
  color: #FF6B6B;
}

.goal-title-section {
  padding: 0 8rpx;
  margin-bottom: 50rpx;
}

.goal-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #1A1A2E;
  display: block;
  line-height: 1.3;
}

.goal-desc {
  font-size: 28rpx;
  color: #6B7280;
  margin-top: 12rpx;
  display: block;
  line-height: 1.5;
}

.goal-status-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #FFE066 0%, #FFA94D 100%);
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  margin-top: 20rpx;
}

.goal-status-tag.active {
  background: linear-gradient(135deg, #B8E6D5 0%, #4ECDC4 100%);
}

.status-emoji {
  font-size: 28rpx;
}

.status-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

.progress-section {
  display: flex;
  align-items: center;
  gap: 40rpx;
  background: #fff;
  padding: 36rpx;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 157, 0.12);
}

.ring-container {
  width: 180rpx;
  height: 180rpx;
  position: relative;
  flex-shrink: 0;
}

.ring-bg-circle {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 14rpx solid #F5F0F6;
}

.ring-progress-circle {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 14rpx solid transparent;
  border-top-color: #FF6B9D;
  border-right-color: #FF6B9D;
  transition: transform 0.6s ease;
}

.ring-inner-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.progress-percent {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF6B9D;
  display: block;
}

.progress-info {
  font-size: 22rpx;
  color: #9CA3AF;
  display: block;
  margin-top: 4rpx;
}

.progress-stats {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.stat-block {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #FFF0F5 0%, #FFE4EC 100%);
  border-radius: 16rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF6B9D;
}

.stat-label {
  font-size: 26rpx;
  color: #6B7280;
}

.main-checkin-section {
  padding: 0 32rpx;
  margin-top: 20rpx;
}

.complete-card {
  background: linear-gradient(135deg, #FFF8DC 0%, #FFE4B5 50%, #FFD700 100%);
  border-radius: 28rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 215, 0, 0.2);
}

.complete-emoji {
  font-size: 100rpx;
  display: block;
  margin-bottom: 24rpx;
}

.complete-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #8B4513;
  display: block;
  margin-bottom: 12rpx;
}

.complete-desc {
  font-size: 28rpx;
  color: #A0522D;
}

.checked-card {
  background: linear-gradient(135deg, #E8F8F5 0%, #B8E6D5 100%);
  border-radius: 28rpx;
  padding: 50rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(78, 205, 196, 0.2);
}

.checked-icon-bg {
  width: 100rpx;
  height: 100rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.2);
}

.checked-icon {
  font-size: 48rpx;
  color: #4ECDC4;
  font-weight: 700;
}

.checked-info {
  flex: 1;
}

.checked-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D7A72;
  display: block;
  margin-bottom: 8rpx;
}

.checked-desc {
  font-size: 26rpx;
  color: #5A9E97;
}

.checkin-btn-card {
  position: relative;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(255, 107, 157, 0.3);
}

.btn-gradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 50%, #FFB347 100%);
}

.btn-content {
  position: relative;
  padding: 60rpx 40rpx;
  text-align: center;
}

.btn-check-icon {
  font-size: 60rpx;
  color: #fff;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
}

.btn-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.btn-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.quick-actions {
  display: flex;
  gap: 24rpx;
  padding: 32rpx 32rpx 0;
}

.action-card {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.action-card.stat {
  background: linear-gradient(135deg, #F5F0F6 0%, #F0E4F5 100%);
}

.action-emoji {
  font-size: 52rpx;
  display: block;
  margin-bottom: 12rpx;
}

.action-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
  margin-bottom: 4rpx;
}

.action-desc {
  font-size: 22rpx;
  color: #9CA3AF;
}

.action-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #8B5CF6;
  margin-top: 8rpx;
  display: block;
}

.section {
  padding: 32rpx 32rpx 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.section-more {
  font-size: 24rpx;
  color: #9CA3AF;
}

.empty-checkins {
  background: #fff;
  border-radius: 24rpx;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
  opacity: 0.8;
}

.empty-text {
  font-size: 28rpx;
  color: #9CA3AF;
  line-height: 1.6;
}

.checkin-list {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.checkin-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F5F0F6;
}

.checkin-item:last-child {
  border-bottom: none;
}

.checkin-date {
  flex: 1;
}

.date-cn {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
}

.weekday {
  font-size: 22rpx;
  color: #9CA3AF;
  display: block;
  margin-top: 4rpx;
}

.checkin-status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.checkin-status-badge.done {
  background: linear-gradient(135deg, #B8E6D5 0%, #4ECDC4 100%);
}

.status-icon {
  font-size: 24rpx;
  color: #fff;
  font-weight: 700;
}

.status-label {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

.undo-btn {
  margin-left: 16rpx;
  padding: 10rpx 20rpx;
  font-size: 22rpx;
  color: #FF6B6B;
  background: #FFF0F0;
  border-radius: 16rpx;
}

.all-dates-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  background: #fff;
  padding: 28rpx;
  border-radius: 24rpx;
}

.date-chip {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #F5F0F6 0%, #F0E4F5 100%);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #8B5CF6;
  font-weight: 500;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  width: 100%;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  padding: 40rpx 32rpx;
  padding-bottom: 60rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.close-btn {
  width: 60rpx;
  height: 60rpx;
  background: #F5F0F6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 32rpx;
  color: #6B7280;
}

.modal-body {
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  color: #6B7280;
  display: block;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  padding: 24rpx 28rpx;
  background: #F5F7FA;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #1A1A2E;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.modal-btn.cancel {
  background: #F5F0F6;
  color: #6B7280;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  color: #fff;
}
