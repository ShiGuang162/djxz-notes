.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  padding-bottom: 140rpx;
}

.profile-header {
  position: relative;
  padding: 48rpx 32rpx 64rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 480rpx;
  background: linear-gradient(135deg, #4ECDC4 0%, #3DBDB5 50%, #2DB5AD 100%);
  border-radius: 0 0 56rpx 56rpx;
}

.header-content {
  position: relative;
  z-index: 1;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 36rpx;
}

.avatar-wrapper {
  position: relative;
  margin-right: 28rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  border: 6rpx solid rgba(255, 255, 255, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 72rpx;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.stats-row {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(78, 205, 196, 0.25);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #4ECDC4;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #5D6D7E;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #E8ECF0;
}

.daily-quote {
  margin: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(78, 205, 196, 0.12);
}

.quote-icon {
  font-size: 40rpx;
  color: #FFE66D;
  margin-bottom: 16rpx;
}

.quote-text {
  font-size: 30rpx;
  color: #5D6D7E;
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.quote-author {
  font-size: 24rpx;
  color: #95A5A6;
  text-align: right;
}

.section {
  margin: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 24rpx rgba(78, 205, 196, 0.12);
}

.section-title {
  padding: 24rpx 32rpx 16rpx;
  font-size: 28rpx;
  color: #95A5A6;
  font-weight: 600;
}

.section-list {
  display: flex;
  flex-direction: column;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  transition: all 0.2s ease;
}

.list-item:active {
  background: rgba(78, 205, 196, 0.05);
}

.item-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.item-icon-wrapper.purple {
  background: linear-gradient(135deg, #E8E4FF 0%, #D4CDFF 100%);
}

.item-icon-wrapper.pink {
  background: linear-gradient(135deg, #FFE8E8 0%, #FFD4D4 100%);
}

.item-icon-wrapper.blue {
  background: linear-gradient(135deg, #E8F4FF 0%, #D4E8FF 100%);
}

.item-icon-wrapper.green {
  background: linear-gradient(135deg, #E8F8F6 0%, #D4F1EE 100%);
}

.item-icon-wrapper.orange {
  background: linear-gradient(135deg, #FFF0E8 0%, #FFE0D4 100%);
}

.item-icon {
  font-size: 36rpx;
}

.item-content {
  flex: 1;
}

.item-title {
  font-size: 32rpx;
  color: #2C3E50;
  font-weight: 600;
}

.item-desc {
  font-size: 24rpx;
  color: #95A5A6;
  margin-top: 4rpx;
}

.item-arrow {
  font-size: 32rpx;
  color: #C0C6CC;
}

.divider {
  height: 1rpx;
  background: #F0F4F8;
  margin: 0 32rpx;
}

.footer {
  padding: 48rpx 32rpx;
  text-align: center;
}

.version-text {
  font-size: 24rpx;
  color: #95A5A6;
}

.settings-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  z-index: 1000;
}

.modal-mask {
  flex: 1;
}

.modal-content {
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C3E50;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-item {
  padding: 28rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.modal-item.primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #E55A5A 100%);
  color: #FFFFFF;
}

.modal-item.default {
  background: #F8FAFC;
  color: #5D6D7E;
}